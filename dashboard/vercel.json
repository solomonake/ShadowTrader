{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://shadowtrader-production.up.railway.app/api/$1"
    },
    {
      "source": "/ws/(.*)",
      "destination": "https://shadowtrader-production.up.railway.app/ws/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
